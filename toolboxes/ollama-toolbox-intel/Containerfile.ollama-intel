# Containerfile for OLLAMA with Intel ARC GPU support
FROM fedora:latest

# Install base packages
RUN dnf install -y \
    podman \
    podman-compose \
    git \
    intel-opencl \
    clinfo \
    && dnf clean all

# Install Intel GPU runtime and Level Zero manually
RUN dnf install -y \
    https://github.com/intel/compute-runtime/releases/download/23.41.27596.14/intel-gmmlib_23.2.0_x86_64.rpm \
    https://github.com/intel/compute-runtime/releases/download/23.41.27596.14/intel-igc-core_1.0.14909.1_x86_64.rpm \
    https://github.com/intel/compute-runtime/releases/download/23.41.27596.14/intel-igc-opencl_1.0.14909.1_x86_64.rpm \
    https://github.com/intel/compute-runtime/releases/download/23.41.27596.14/intel-opencl_23.41.27596.14_x86_64.rpm \
    https://github.com/intel/compute-runtime/releases/download/23.41.27596.14/intel-ocloc_23.41.27596.14_x86_64.rpm \
    https://github.com/intel/compute-runtime/releases/download/23.41.27596.14/libigc_1.0.14909.1_x86_64.rpm \
    https://github.com/intel/compute-runtime/releases/download/23.41.27596.14/level-zero_1.13.0_x86_64.rpm \
    https://github.com/intel/compute-runtime/releases/download/23.41.27596.14/level-zero-devel_1.13.0_x86_64.rpm \
    && dnf clean all

# Set up user and permissions for /dev/dri
RUN usermod --add-subuids 100000-165535 --add-subgids 100000-165535 root

# Documentation
LABEL com.example.description="Fedora-based Toolbox for OLLAMA with Intel ARC GPU support"
LABEL com.example.version="1.0"
LABEL com.example.maintainer="André K. <andre@example.com>"

# Set working directory
WORKDIR /opt/ollama