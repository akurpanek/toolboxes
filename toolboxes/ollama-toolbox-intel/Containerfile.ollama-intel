# Containerfile for OLLAMA with Intel ARC GPU support
FROM fedora:latest

# Install only the most critical packages
RUN dnf install -y \
    podman \
    podman-compose \
    git \
    intel-opencl \
    clinfo \
    && dnf clean all

# Set up user and permissions for /dev/dri
RUN usermod --add-subuids 100000-165535 --add-subgids 100000-165535 root

# Create /opt/ollama directory and embed podman-compose.yml
RUN mkdir -p /opt/ollama && \
    cat > /opt/ollama/podman-compose.yml << 'EOF'
version: '3'
services:
  ollama:
    image: ghcr.io/ipex-llm/ollama-ipex:latest
    container_name: ollama
    restart: unless-stopped
    ports:
      - "11434:11434"
    volumes:
      - ollama-data:/root/.ollama
    devices:
      - "/dev/dri:/dev/dri"
    environment:
      - OLLAMA_MAX_LOADED_MODELS=1
      - OLLAMA_NUM_PARALLEL=1

  open-webui:
    image: ghcr.io/open-webui/open-webui:main
    container_name: open-webui
    restart: unless-stopped
    ports:
      - "8080:8080"
    volumes:
      - open-webui-data:/app/backend/data
    environment:
      - OLLAMA_BASE_URL=http://ollama:11434
    depends_on:
      - ollama

volumes:
  ollama-data:
  open-webui-data:
EOF

# Documentation
LABEL com.example.description="Fedora-based Toolbox for OLLAMA with Intel ARC GPU support"
LABEL com.example.version="1.0"
LABEL com.example.maintainer="André K. <andre@example.com>"

# Set working directory
WORKDIR /opt/ollama